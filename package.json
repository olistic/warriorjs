{
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://warrior.js.org",
  "repository": "https://github.com/olistic/warriorjs",
  "scripts": {
    "build": "turbo run build --filter='!warriorjs-website'",
    "clean": "rm -rf packages/*/lib",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,json,css,md,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
