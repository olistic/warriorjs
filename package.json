{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://warrior.js.org",
  "repository": "https://github.com/olistic/warriorjs",
  "scripts": {
    "build": "turbo run build --filter='!warriorjs-website'",
    "clean": "rm -rf packages/*/lib",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "lefthook": "^2.1.4",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["lefthook"]
  }
}
