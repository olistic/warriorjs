{
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "packageManager": "yarn@1.22.22",
  "homepage": "https://warrior.js.org",
  "repository": "https://github.com/olistic/warriorjs",
  "scripts": {
    "build": "turbo run build --filter='!warriorjs-website'",
    "clean": "rm -rf packages/*/lib",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "husky": "^1.2.0",
    "lint-staged": "^8.1.0",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,json,css,md,yaml}": [
      "biome check --write --no-errors-on-unmatched",
      "git add"
    ]
  }
}
