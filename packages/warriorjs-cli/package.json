{
  "name": "@warriorjs/cli",
  "version": "0.14.0",
  "description": "WarriorJS command line",
  "author": "Matias Olivera <hi@matiasolivera.com>",
  "license": "MIT",
  "homepage": "https://warrior.js.org",
  "repository": "https://github.com/olistic/warriorjs/tree/master/packages/warriorjs-cli",
  "type": "module",
  "keywords": [
    "warriorjs",
    "warriorjs-cli",
    "warrior",
    "epic",
    "battle",
    "game",
    "learn",
    "polish",
    "refine",
    "test",
    "js",
    "javascript",
    "nodejs",
    "ai",
    "artificial-intelligence",
    "skills"
  ],
  "bin": {
    "warriorjs": "./bin/warriorjs.js"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "lib/cli.js",
  "exports": {
    ".": {
      "import": "./lib/cli.js",
      "types": "./lib/cli.d.ts"
    }
  },
  "files": [
    "bin",
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "node -e \"console.log('\\u001b[35m\\u001b[1mLove WarriorJS? You can now donate to our open collective:\\u001b[22m\\u001b[39m\\n> \\u001b[34mhttps://opencollective.com/warriorjs/donate\\u001b[0m')\""
  },
  "devDependencies": {
    "mock-fs": "^5.5.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@warriorjs/core": "workspace:^",
    "@warriorjs/helper-get-grade-letter": "workspace:^",
    "@warriorjs/helper-get-level-config": "workspace:^",
    "@warriorjs/helper-get-level-score": "workspace:^",
    "@warriorjs/tower-the-narrow-path": "workspace:^",
    "ansi-escapes": "^7.0.0",
    "array-shuffle": "^3.0.0",
    "chalk": "^5.4.0",
    "delay": "^6.0.0",
    "find-up": "^7.0.0",
    "globby": "^14.0.0",
    "string-width": "^7.0.0",
    "yargs": "^17.0.0"
  }
}
